{
    "name": "wintech/erp-gia",
    "version": "2.5.0",
    "description": "Système de Gestion Intégrée - YAOCOM'S GROUPE",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "setasign/fpdf": "^1.8",
        "phpmailer/phpmailer": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
